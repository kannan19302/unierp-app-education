generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Student {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  dateOfBirth      DateTime @map("date_of_birth")
  enrollmentNumber String   @map("enrollment_number")
  status           String   @default("ACTIVE")
  parentContact    Json     @map("parent_contact")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  fees             StudentFee[]
  bookTransactions BookTransaction[]

  @@unique([tenantId, enrollmentNumber])
  @@index([tenantId])
  @@map("students")
}

model Course {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  credits     Int
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  timetables Timetable[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("courses")
}

model Timetable {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  courseId     String   @map("course_id")
  room         String
  weekday      String
  startTime    String   @map("start_time") // HH:MM
  endTime      String   @map("end_time") // HH:MM
  instructorId String   @map("instructor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("timetables")
}

model FeeStructure {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  amount      Decimal  @db.Decimal(15, 2)
  dueDate     DateTime @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  fees StudentFee[]

  @@index([tenantId])
  @@map("fee_structures")
}

model StudentFee {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  studentId      String   @map("student_id")
  feeStructureId String   @map("fee_structure_id")
  amountPaid     Decimal  @default(0) @map("amount_paid") @db.Decimal(15, 2)
  balance        Decimal  @map("balance") @db.Decimal(15, 2)
  status         String   @default("UNPAID") // PAID, PARTIAL, UNPAID
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("student_fees")
}

model BookRegister {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  title     String
  isbn      String
  author    String
  quantity  Int
  available Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions BookTransaction[]

  @@unique([tenantId, isbn])
  @@index([tenantId])
  @@map("book_register")
}

model BookTransaction {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  studentId    String    @map("student_id")
  bookId       String    @map("book_id")
  checkoutDate DateTime  @map("checkout_date")
  dueDate      DateTime  @map("due_date")
  returnDate   DateTime? @map("return_date")
  fineAmount   Decimal   @default(0) @map("fine_amount") @db.Decimal(15, 2)
  status       String    @default("ISSUED") // ISSUED, RETURNED, OVERDUE
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    BookRegister @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("book_transactions")
}


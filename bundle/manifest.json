{
  "name": "Education",
  "slug": "education",
  "version": "1.1.0",
  "apiVersion": 1,
  "category": "Industry",
  "vendor": "unierp",
  "runtime": "declarative+service",
  "description": "Student registry, courses, timetables, fees, and library management.",
  "longDescription": "Education for UniERP: manage student enrollment, course catalogs, timetables, fee structures and payments, grades, attendance, transcripts, and a library book register. Runs as its own service; install/uninstall in real time.",
  "icon": "graduation-cap",
  "pricing": "FREE",
  "tags": [
    "education",
    "students",
    "courses",
    "fees",
    "library"
  ],
  "service": {
    "routePrefix": "education",
    "baseUrlEnv": "EDUCATION_SERVICE_URL",
    "defaultBaseUrl": "http://localhost:4101",
    "healthcheck": "/svc/health",
    "scopes": [
      "education:read",
      "education:write"
    ],
    "timeoutMs": 15000
  },
  "pages": [
    {
      "slug": "students",
      "title": "Students",
      "type": "remote",
      "layout": {
        "dataUrl": "students",
        "columns": [
          {
            "key": "firstName"
          },
          {
            "key": "lastName"
          },
          {
            "key": "enrollmentNumber"
          },
          {
            "key": "status"
          }
        ]
      }
    },
    {
      "slug": "courses",
      "title": "Courses",
      "type": "remote",
      "layout": {
        "dataUrl": "courses",
        "columns": [
          {
            "key": "name"
          },
          {
            "key": "code"
          },
          {
            "key": "credits"
          },
          {
            "key": "status"
          }
        ]
      }
    },
    {
      "slug": "student-fees",
      "title": "Student Fees",
      "type": "remote",
      "layout": {
        "dataUrl": "student-fees",
        "columns": [
          {
            "key": "studentId"
          },
          {
            "key": "balance"
          },
          {
            "key": "status"
          }
        ]
      }
    },
    {
      "slug": "books",
      "title": "Library",
      "type": "remote",
      "layout": {
        "dataUrl": "books",
        "columns": [
          {
            "key": "title"
          },
          {
            "key": "author"
          },
          {
            "key": "isbn"
          },
          {
            "key": "available"
          }
        ]
      }
    }
  ]
}
